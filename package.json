{
  "name": "zotero-citegeist",
  "version": "3.0.0",
  "description": "Citation intelligence for Zotero — powered by OpenAlex. See citation counts, explore citation networks, and add citing/cited works to your library.",
  "homepage": "https://github.com/phdemotions/zotero-citegeist",
  "author": "Josh Gonzales",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:dev": "node scripts/build.mjs --dev",
    "start": "node scripts/build.mjs --dev && node scripts/start.mjs",
    "release": "bumpp --commit 'release: v%s' --tag 'v%s' --push",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"*.{json,md,mjs}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"*.mjs\"",
    "okf:check": "bash tools/okf-check.sh",
    "okf:drift": "bash tools/okf-drift-check.sh"
  },
  "config": {
    "addonName": "Citegeist",
    "addonID": "citegeist@opusvita.org",
    "addonRef": "citegeist",
    "addonInstance": "Citegeist",
    "prefsPrefix": "extensions.zotero.citegeist",
    "zoteroMinVersion": "7.0.10",
    "zoteroMaxVersion": "9.*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "bumpp": "^11.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
